{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "outputDirectory": null,
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "functions": {
    "api/[...all].ts": {
      "runtime": "@vercel/node@5.1.14",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
