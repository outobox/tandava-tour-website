# =============================================================================
# Tandava Tour Company — Environment Variable Template
# =============================================================================
# Copy this file to `.env` and fill in real values, OR set each variable as a
# Replit Secret (recommended). NEVER commit a real `.env` file.
# Required variables in production are marked [REQUIRED IN PROD].
# =============================================================================

# ---- Core runtime --------------------------------------------------------
NODE_ENV=development
PORT=8080

# ---- Database (Replit-managed Postgres) ----------------------------------
# [REQUIRED IN PROD]
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Admin credentials ---------------------------------------------------
# [REQUIRED IN PROD] — username for the admin login screen
ADMIN_USERNAME=admin

# Provide ONE of the two below:
# Preferred: a pre-computed bcrypt hash (use `bcrypt.hashSync('your-password', 12)`)
ADMIN_PASSWORD_HASH=

# Convenience fallback: plain password (>= 8 chars). The server will hash it on boot.
ADMIN_PASSWORD=

# ---- Session security ----------------------------------------------------
# [REQUIRED IN PROD] — at least 32 random bytes recommended.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=

# ---- CORS ---------------------------------------------------------------
# Comma-separated list of allowed origins. Leave empty to auto-allow the
# Replit dev domain in development and the Replit deploy domain in production.
# REQUIRED on Vercel split deployments — the API project must list the
# frontend's deploy URL(s) so the browser can send session cookies.
# Example: ALLOWED_ORIGINS=https://tandavatours.com,https://www.tandavatours.com
ALLOWED_ORIGINS=

# ---- Frontend → API URL (Vite, exposed to the browser) -------------------
# Only needed when the frontend and API are deployed to *different* origins
# (the typical Vercel split-project setup). When set, the React app prepends
# this URL to every relative `/api/...` request and includes credentials so
# the admin session cookie travels cross-origin. Leave empty for same-origin
# deployments (single domain) and for local development (the Vite dev server
# proxies `/api/*` to the local API).
# Example: VITE_API_URL=https://tandava-api.vercel.app
VITE_API_URL=

# ---- Object Storage (Replit App Storage / Google Cloud Storage) ----------
# Required only if file uploads are enabled.
PUBLIC_OBJECT_SEARCH_PATHS=
PRIVATE_OBJECT_DIR=

# =============================================================================
# Reserved for future integrations — leave blank unless used:
# =============================================================================
# JWT_SECRET=
# GOOGLE_PLACES_API_KEY=
# INSTAGRAM_ACCESS_TOKEN=
# EMAIL_USER=
# EMAIL_PASS=
# UPLOAD_SECRET=
